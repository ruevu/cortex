{
  "name": "cortex",
  "version": "0.1.0",
  "description": "Knowledge graph MCP server with decision provenance",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "postinstall": "bash scripts/build-indexer.sh",
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "CORTEX_VIEWER_PORT=3334 tsx src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "survey:phase1": "tsx scripts/frame-extraction/survey.ts",
    "survey:report": "tsx scripts/frame-extraction/report.ts",
    "co-change": "tsx scripts/frame-extraction/co-change.ts",
    "cluster:tfidf": "tsx scripts/frame-extraction/cluster-tfidf-hdbscan.ts",
    "eval:phase2": "tsx scripts/frame-extraction/eval.ts",
    "setup-python": "bash scripts/frame-extraction/python/setup-venv.sh"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "better-sqlite3": "^11.8.1",
    "chokidar": "^5.0.0",
    "ulid": "^3.0.2",
    "ws": "^8.20.0",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.15.2",
    "@types/ws": "^8.18.1",
    "d3-force": "^3.0.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3",
    "vitest": "^3.1.2"
  }
}
